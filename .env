# Template only: keep everything commented so this file does not affect Zeabur deployments.
# For local development, copy the values you need from .env.example and uncomment them here.

# Local MySQL example
# PORT=3000
# NODE_ENV=development
# ADMIN_ENTRY_CODE=change_me
#
# DB_CLIENT=mysql
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=mingzhita
# MYSQL_PASSWORD=change_me
# MYSQL_DATABASE=mingzhita
# MYSQL_CHARSET=utf8mb4

# Local SQLite fallback
# DB_CLIENT=sqlite
# DB_PATH=./data/game.db

# Optional when migrating existing data from SQLite to MySQL
# SQLITE_IMPORT_PATH=./data/game.db

# Optional when frontend/backend are split across domains
# VITE_API_BASE=https://your-domain.example.com
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000
